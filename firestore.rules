rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "abc198534a@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidAnalysisLog(data) {
      return hasRequiredFields(['type', 'scale', 'isRoastMode', 'language', 'results', 'timestamp']) &&
             data.type in ['text', 'image', 'video'] &&
             data.scale in [100, 1000, 10000] &&
             data.language is string &&
             data.results is map &&
             data.timestamp is timestamp;
    }

    function isValidBattleLog(data) {
      return hasRequiredFields(['ideaA', 'ideaB', 'language', 'results', 'timestamp']) &&
             data.ideaA is string && data.ideaA.size() < 5000 &&
             data.ideaB is string && data.ideaB.size() < 5000 &&
             data.language is string &&
             data.results is map &&
             data.timestamp is timestamp;
    }

    function isValidConsultationLog(data) {
      return hasRequiredFields(['initialMessage', 'history', 'timestamp']) &&
             data.initialMessage is string && data.initialMessage.size() < 2000 &&
             data.history is list &&
             data.timestamp is timestamp;
    }

    function isValidConsultationMessage(data) {
      return hasRequiredFields(['chatId', 'userMessage', 'modelResponse', 'timestamp']) &&
             data.chatId is string &&
             data.userMessage is string && data.userMessage.size() < 2000 &&
             data.modelResponse is string && data.modelResponse.size() < 10000 &&
             data.timestamp is timestamp;
    }

    function isValidFeedback(data) {
      return hasRequiredFields(['logId', 'isAccurate', 'timestamp']) &&
             data.logId is string &&
             data.isAccurate is bool &&
             data.timestamp is timestamp;
    }

    function isValidUserCreate(data) {
      return hasRequiredFields(['email', 'credits', 'plan', 'createdAt']) &&
             data.email == request.auth.token.email &&
             data.credits == 3 &&
             data.plan == 'free' &&
             data.createdAt is timestamp;
    }

    function isValidUserUpdate(data, prevData) {
      // Only allow decrementing credits by exactly 1
      return data.diff(prevData).affectedKeys().hasOnly(['credits']) &&
             data.credits == prevData.credits - 1 &&
             data.credits >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserCreate(request.resource.data);
      allow update: if isOwner(userId) && isValidUserUpdate(request.resource.data, resource.data);
    }

    match /analysis_logs/{logId} {
      allow create: if isValidAnalysisLog(request.resource.data);
      allow read: if isAdmin();
    }

    match /battle_logs/{logId} {
      allow create: if isValidBattleLog(request.resource.data);
      allow read: if isAdmin();
    }

    match /consultation_logs/{logId} {
      allow create: if isValidConsultationLog(request.resource.data);
      allow read: if isAdmin();
    }

    match /consultation_messages/{msgId} {
      allow create: if isValidConsultationMessage(request.resource.data);
      allow read: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if isValidFeedback(request.resource.data);
      allow read: if isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
